{
  "name": "microv-mdx",
  "version": "0.1.9",
  "description": "MDX file reading and rendering for Next.js App Router (next-mdx-remote, preview fences, typography)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/globals.css": "./dist/styles/globals.css",
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ./scripts/copy-styles.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mdx",
    "next.js",
    "next-mdx-remote",
    "react",
    "rsc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/microv-base",
    "directory": "packages/microv-mdx"
  },
  "peerDependencies": {
    "next": ">=14",
    "next-themes": "^0.4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "next-mdx-remote": "^5.0.0",
    "radix-ui": "^1.4.3",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "eslint": "^9.39.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
